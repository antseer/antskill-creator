{
  "id": "skill-creator-rick",
  "name": "Skill Creator Rick",
  "description": "Classify, scaffold, validate, package, and publish skills through Stage 1 Requirement and Stage 2 Complete lifecycles.",
  "input_schema": {
    "zh": {
      "action": {
        "type": "select",
        "label": "操作类型",
        "default": "review",
        "options": [
          { "label": "审计", "value": "review" },
          { "label": "生成脚手架", "value": "scaffold" },
          { "label": "校验", "value": "validate" },
          { "label": "打包", "value": "package" },
          { "label": "拆分规划", "value": "split" }
        ],
        "description": "选择本次要执行的 skill 包装动作。",
        "required": true
      },
      "target_path": {
        "type": "input",
        "label": "目标路径",
        "default": "",
        "options": [],
        "description": "要审计、生成、校验或打包的本地 skill 目录路径。",
        "required": false
      },
      "stage": {
        "type": "select",
        "label": "阶段",
        "default": "auto",
        "options": [
          { "label": "自动判断", "value": "auto" },
          { "label": "Stage 1 需求型", "value": "requirement" },
          { "label": "Stage 2 完整型", "value": "complete" }
        ],
        "description": "指定校验或包装阶段；不确定时使用自动判断。",
        "required": false
      }
    },
    "en": {
      "action": {
        "type": "select",
        "label": "Action",
        "default": "review",
        "options": [
          { "label": "Review", "value": "review" },
          { "label": "Scaffold", "value": "scaffold" },
          { "label": "Validate", "value": "validate" },
          { "label": "Package", "value": "package" },
          { "label": "Split plan", "value": "split" }
        ],
        "description": "Choose the skill packaging action to run.",
        "required": true
      },
      "target_path": {
        "type": "input",
        "label": "Target path",
        "default": "",
        "options": [],
        "description": "Local skill directory to review, scaffold, validate, or package.",
        "required": false
      },
      "stage": {
        "type": "select",
        "label": "Stage",
        "default": "auto",
        "options": [
          { "label": "Auto detect", "value": "auto" },
          { "label": "Stage 1 Requirement", "value": "requirement" },
          { "label": "Stage 2 Complete", "value": "complete" }
        ],
        "description": "Packaging stage to validate or apply; use auto when unsure.",
        "required": false
      }
    }
  }
}
